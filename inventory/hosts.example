# ============================================
# Ansible Inventory — Hybrid Lab
# ============================================

[homelab]
devopslab ansible_host=YOUR_HOMELAB_IP ansible_user=ubuntu

[companylab]
k8s-master    ansible_host=YOUR_MASTER_IP    ansible_user=ubuntu
k8s-worker-01 ansible_host=YOUR_WORKER01_IP  ansible_user=ubuntu
k8s-worker-02 ansible_host=YOUR_WORKER02_IP  ansible_user=ubuntu

[proxmox]
pve01 ansible_host=YOUR_PVE01_IP ansible_user=root
pve02 ansible_host=YOUR_PVE02_IP ansible_user=root

[all:vars]
ansible_ssh_private_key_file=~/.ssh/id_rsa
ansible_python_interpreter=/usr/bin/python3
